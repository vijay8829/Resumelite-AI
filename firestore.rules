rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function emailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email'])
        && data.uid == request.auth.uid
        && data.email is string
        && data.email.size() <= 200
        && (!data.keys().hasAny(['displayName']) || data.displayName is string || data.displayName == null)
        && (!data.keys().hasAny(['photoURL']) || data.photoURL is string || data.photoURL == null)
        && (!data.keys().hasAny(['updatedAt']) || data.updatedAt == request.time);
    }

    function isValidResume(data) {
      return data.keys().hasAll(['id', 'userId', 'title'])
        && data.id is string && data.id.size() <= 128
        && data.userId == request.auth.uid
        && data.title is string && data.title.size() <= 200
        && (!data.keys().hasAny(['personalInfo']) || data.personalInfo is map)
        && (!data.keys().hasAny(['experience']) || data.experience is list)
        && (!data.keys().hasAny(['education']) || data.education is list)
        && (!data.keys().hasAny(['skills']) || data.skills is list)
        && (!data.keys().hasAny(['projects']) || data.projects is list)
        && (!data.keys().hasAny(['updatedAt']) || data.updatedAt == request.time);
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['phone', 'targetRole', 'industries', 'location', 'marketTier', 'displayName', 'updatedAt'])
        && data.phone is string && data.phone.size() <= 64
        && data.targetRole is string && data.targetRole.size() <= 200
        && data.industries is string && data.industries.size() <= 500
        && data.location is string && data.location.size() <= 200
        && data.marketTier is string && data.marketTier.size() <= 200
        && data.displayName is string && data.displayName.size() <= 200
        && data.updatedAt == request.time;
    }

    // 3. Match Blocks
    match /users/{userId} {
      allow get: if isOwner(userId);
      // Create and Update must respect the blueprint and verify email
      allow create: if isOwner(userId) && emailVerified() && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && emailVerified() && isValidUser(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'email', 'updatedAt']);
      
      match /resumes/{resumeId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && emailVerified() && isValidId(resumeId) && isValidResume(request.resource.data);
        allow update: if isOwner(userId) && emailVerified() && isValidResume(request.resource.data)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'personalInfo', 'experience', 'education', 'skills', 'projects', 'updatedAt']);
        allow delete: if isOwner(userId) && emailVerified();
      }
    }

    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && emailVerified() && isValidUserProfile(request.resource.data);
      allow update: if isOwner(userId) && emailVerified() && isValidUserProfile(request.resource.data);
    }
  }
}
